# Bullcast frontend environment variables.
# Vite exposes variables prefixed with VITE_ to the browser bundle.
# Do not put secrets in frontend environment variables.

# Local backend default:
VITE_API_URL=http://127.0.0.1:8000

# Vercel production example:
# VITE_API_URL=https://your-bullcast-backend.example.com

# Optional Supabase persistence. Use the project URL and anon/publishable key only.
# Never put a service role or secret key in frontend environment variables.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
