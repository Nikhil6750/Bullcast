{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,trading-ui/**,node_modules/**,.venv/**,venv/**,backend/models/**,data/**,dev_data/**,output/**,rag_db/**,**/__pycache__/**,*.pyc}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
